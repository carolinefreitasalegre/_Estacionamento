@page
@using Estacionamento.Dtos.Response
@using Estacionamento.Models


<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="row w-100 ">
        <div class="col-md-6">
            <div class="card shadow-sm p-3 mb-4 bg-white rounded">
                <div class="card-body">
                    <h5 class="card-title">Fluxo de Veículos (Hoje)</h5>
                    <div id="grafico-fluxo"></div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm p-3 mb-4 bg-white rounded">
                <div class="card-body">
                    <h5 class="card-title">Status de Ocupação do Pátio</h5>
                    <div id="grafico-ocupacao"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
  <script>
    var dados = @Html.Raw(ViewBag.DadosGraficoJson ?? "[]");
    var fluxoPorHora = {};
    var contador = 0;
    
    dados.forEach(function (item) {
        
        if(!item.Finalizado){
            contador++;
        }
        
        if (item.Entrada) {
            var horaEntrada = new Date(item.Entrada).getHours();
            if (!fluxoPorHora[horaEntrada]) fluxoPorHora[horaEntrada] = { entrada: 0, saida: 0 };
            fluxoPorHora[horaEntrada].entrada++;
        }

        if (item.Saida) {
            var horaSaida = new Date(item.Saida).getHours();
            if (!fluxoPorHora[horaSaida]) fluxoPorHora[horaSaida] = { entrada: 0, saida: 0 };
            fluxoPorHora[horaSaida].saida++;
        }
    });

    var horasOrdenadas = Object.keys(fluxoPorHora).sort(function (a, b) {
        return parseInt(a) - parseInt(b);
    });

    var labels = horasOrdenadas.map(function (h) { return h + 'h'; });
    var entrada = horasOrdenadas.map(function (h) { return fluxoPorHora[h].entrada; });
    var saida = horasOrdenadas.map(function (h) { return fluxoPorHora[h].saida; });

    var optionsFluxo = {
        series: [
            { name: 'Entradas', data: entrada },
            { name: 'Saídas', data: saida }
        ],
        chart: { height: 350, type: 'area', toolbar: { show: false } },
        colors: ['#007bff', '#dc3545'],
        dataLabels: { enabled: false },
        stroke: { curve: 'smooth', width: 3 },
        xaxis: { categories: labels },
        fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05, stops: [0, 90, 100] } }
    };

    var chartFluxo = new ApexCharts(document.querySelector('#grafico-fluxo'), optionsFluxo);
    chartFluxo.render();


    var vagasOcupadas = dados.filter(function (item) {
        return item.Entrada && !item.Saida;
    }).length;

    var capacidadeTotal = 100; 
    var vagasLivres = Math.max(capacidadeTotal - contador, 0);

    var optionsOcupacao = {
        series: [vagasOcupadas, vagasLivres],
        chart: {
            height: 370,
            type: 'donut',
        },
        labels: ['Vagas Ocupadas', 'Vagas Livres'],
        colors: ['#007bff', '#e9ecef'],
        plotOptions: {
            pie: {
                donut: {
                    size: '75%',
                    labels: {
                        show: true,
                        name: {
                            show: true,
                            fontSize: '14px',
                            fontWeight: 600,
                            color: '#6c757d',
                            offsetY: -10
                        },
                        value: {
                            show: true,
                            fontSize: '24px',
                            fontWeight: 700,
                            color: '#343a40',
                            offsetY: 10,
                            formatter: function (val) {
                                return val + " vagas";
                            }
                        },
                        total: {
                            show: true,
                            label: 'Capacidade Total',
                            color: '#6c757d',
                            formatter: function (w) {
                                return w.globals.seriesTotals.reduce((a, b) => a + b, 0) + " vagas";
                            }
                        }
                    }
                }
            }
        },
        legend: {
            position: 'bottom',
            fontSize: '13px',
            fontWeight: 500
        },
        dataLabels: {
            enabled: true,
            dropShadow: { enabled: false }
        }
    };

    var chartOcupacao = new ApexCharts(document.querySelector('#grafico-ocupacao'), optionsOcupacao);
    chartOcupacao.render();
</script>
}
<style>
    .card {
        transition: box-shadow 0.3s ease;
    }

        .card:hover {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

    .icon-circle {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
    }

    .blue-icon {
        background-color: #EBF5FF;
        color: #2563EB;
    }

    .green-icon {
        background-color: #ECFDF5;
        color: #059669;
    }

    .purple-icon {
        background-color: #F5F3FF;
        color: #7C3AED;
    }
</style>


